{{ define "preview.tmpl" }}
<!DOCTYPE html>
<html lang="en" data-theme="light">
<head>
	<meta charset="UTF-8" />
	<meta name="viewport" content="width=device-width, initial-scale=1.0" />
	<title>{{ .Title }}</title>
	<style>
		:root {
			color-scheme: light dark;
			--bg: #f4f6fb;
			--fg: #0f172a;
			--accent: #2563eb;
			--muted: #64748b;
			--surface: #ffffff;
			--code-bg: #f1f5f9;
		}
		:root[data-theme="dark"] {
			--bg: #0f172a;
			--fg: #e2e8f0;
			--accent: #8da2c9;
			--muted: #9ca3af;
			--surface: #111827;
			--code-bg: #1f2937;
		}
		body { margin: 0; font-family: "Inter", system-ui, sans-serif; background: var(--bg); color: var(--fg); min-height: 100vh; transition: background .3s ease, color .3s ease; }
		.container { max-width: 860px; margin: 0 auto; padding: 3rem 1.75rem 4rem; display: flex; flex-direction: column; gap: 1.75rem; position: relative; }
		.alert { background: var(--surface); border-radius: 16px; padding: 1.25rem 1.5rem; border: 1px solid rgba(148, 163, 184, 0.3); display: flex; flex-wrap: wrap; gap: 0.75rem; align-items: center; box-shadow: 0 12px 36px rgba(15, 23, 42, 0.12); }
		.alert strong { font-weight: 700; }
		.alert span { color: var(--muted); font-size: 0.9rem; }
		.article { line-height: 1.75; background: var(--surface); border-radius: 22px; padding: 2.2rem; border: 1px solid rgba(148, 163, 184, 0.22); box-shadow: 0 20px 50px rgba(15, 23, 42, 0.1); }
		.article h1, .article h2, .article h3 { line-height: 1.2; margin-top: 2.4rem; }
		.article pre { background: var(--code-bg); padding: 1rem 1.25rem; border-radius: 12px; overflow-x: auto; }
		.article code { font-family: "Fira Code", monospace; }
		@media (max-width: 720px) {
			.container { padding-top: 2.5rem; padding-bottom: 3rem; }
			.article { padding: 1.65rem; }
		}
	</style>
</head>
<body>
	<div class="container">
		<div class="alert">
			<strong>Preview mode</strong>
			<span>Content is not saved yet{{ if .GeneratedAt }} · Generated {{ .GeneratedAt }}{{ end }}{{ if .Slug }} · slug: {{ .Slug }}{{ end }}</span>
		</div>
		<article class="article">
			{{ .HTML }}
		</article>
	</div>
</body>
</html>
{{ end }}
